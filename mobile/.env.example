# API server URL.
# Web dev (Expo dev server): set to http://localhost:3000
# Native (iOS/Android on a physical device): set to your server's LAN IP, e.g. http://192.168.1.100:3000
# Web production (served from the API itself): leave unset — same-origin requests are used automatically.
EXPO_PUBLIC_API_URL=http://localhost:3000
